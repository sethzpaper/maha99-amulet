# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# (อย่า commit .env เข้า git!)

# Internal Integration Token จาก Notion
# ขึ้นต้นด้วย secret_ หรือ ntn_
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database ID ของ "Mahaniyom Asset"
# คัดลอกจาก URL ของ DB เช่น
#   https://www.notion.so/workspace/abc123def456...?v=...
#                                  ^^^^^^^^^^^^^^^^^^^ ส่วนนี้คือ ID
# (32 ตัวอักษร hex หรือใส่ hyphen ก็ได้ โค้ด normalize ให้)
NOTION_DATABASE_ID=abcdef1234567890abcdef1234567890

# Discord Time Tracking Bot
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_id
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret

# Database backend: use sqlite for local tests, supabase for production
DATABASE_BACKEND=supabase
SUPABASE_URL=https://your-project.supabase.co
# Server only. Never place the service role key in Discord or browser JavaScript.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_REPORTS_BUCKET=attendance-reports
SUPABASE_ASSETS_BUCKET=video-assets
# Optional on non-Windows hosts when PDF reports contain Thai text
REPORT_FONT_PATH=
REPORT_BOLD_FONT_PATH=

# Discord Activity + background worker
ACTIVITY_HOST=127.0.0.1
ACTIVITY_PORT=8092
# Local browser preview only. Keep false in production.
ACTIVITY_DEV_BYPASS=false
AI_JOB_WEBHOOK_URL=https://your-ai-orchestration-endpoint.example/jobs
JOB_WORKER_POLL_SECONDS=5

# Optional: ใส่ Guild ID ตอนพัฒนาเพื่อให้ slash commands sync เร็วขึ้น
DISCORD_GUILD_ID=

# Optional: จำกัดคำสั่งให้ใช้ได้เฉพาะห้อง #attendance
ATTENDANCE_CHANNEL_ID=

# Optional: ห้อง #attendance-log สำหรับส่ง log
ATTENDANCE_LOG_CHANNEL_ID=

# Optional: webhook ภายนอก เช่น HR DB / automation / Notion bridge
ATTENDANCE_WEBHOOK_URL=

# Default ใช้เวลาไทย
TIMEZONE=Asia/Bangkok
ATTENDANCE_DB_PATH=runtime/attendance.sqlite3
ATTENDANCE_DEFAULT_DAILY_RATE=400

# Worktime admin web
# เปิดผ่าน http://127.0.0.1:8080/?token=ค่าที่ตั้งไว้ด้านล่าง
ADMIN_WEB_HOST=127.0.0.1
ADMIN_WEB_PORT=8080
ADMIN_WEB_TOKEN=replace_with_a_long_random_secret

# AI Video Pipeline Bot
VIDEO_PIPELINE_DB_PATH=runtime/video_pipeline.sqlite3

# Master channel: #ai-video-pipeline
VIDEO_MASTER_CHANNEL_ID=

# Approved channel: #approved-videos
VIDEO_APPROVED_CHANNEL_ID=

# Optional stage mirror channels
VIDEO_STAGE_IDEA_CHANNEL_ID=
VIDEO_STAGE_IMAGE_GEN_CHANNEL_ID=
VIDEO_STAGE_STORYBOARD_CHANNEL_ID=
VIDEO_STAGE_RENDER_CHANNEL_ID=
VIDEO_STAGE_REVIEW_CHANNEL_ID=
VIDEO_STAGE_EDITS_CHANNEL_ID=
VIDEO_STAGE_APPROVED_CHANNEL_ID=

# Optional external metadata webhook: Notion/Supabase/Postgres/Drive index bridge
VIDEO_PIPELINE_WEBHOOK_URL=
